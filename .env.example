# =============================================================================
# .env.example — apenas NOMES de variáveis e PLACEHOLDERS. Sem valores reais.
# Copie para .env.local (NÃO versionado) e preencha. Em produção use o painel
# do Vercel / GitHub Secrets. Veja docs/SECRETS.md.
# =============================================================================

# --- Meta Marketing API ---
# Long-lived user token OU system-user token do Business Manager (escopo ads_read).
# Geração: ver README.md > "Pré-requisitos manuais".
META_ACCESS_TOKEN=replace_me

# ID numérico da conta de anúncios, SEM o prefixo "act_".
META_AD_ACCOUNT_ID=replace_me

# Versão fixada da Graph API.
META_GRAPH_API_VERSION=v21.0

# --- App auth (basic auth via middleware) ---
BASIC_AUTH_USER=replace_me
BASIC_AUTH_PASS=replace_me

# --- Link público da Visão Geral (sem login) ---
# Token secreto do link /publico/<token>. OPCIONAL: sem ele, a rota fica fechada
# atrás do basic auth (fail-closed). Gere um valor aleatório longo e trate como
# secret; TROCAR o valor REVOGA o link. Nunca indexado (noindex).
# Gerar: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
PUBLIC_SHARE_TOKEN=replace_me

# --- Plano de saúde (snapshot do funil) ---
# URL de onde o snapshot é buscado em runtime (ver src/lib/plano-saude.ts).
PLANO_SAUDE_SNAPSHOT_URL=replace_me

# --- Chatwoot ---
CHATWOOT_BASE_URL=replace_me
CHATWOOT_ACCOUNT_ID=replace_me
CHATWOOT_API_TOKEN=replace_me

# --- Opcional ---
NEXT_PUBLIC_APP_URL=replace_me
